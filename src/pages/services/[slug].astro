---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header';
import Footer from '../../components/Footer.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { SERVICES } from '@/constants';
import type { Service } from '@/types';

const FALLBACK_IMG =
  'https://images.unsplash.com/photo-1563453392212-326f5e854473?auto=format&fit=crop&q=60&w=640';

export function getStaticPaths() {
  return SERVICES.map((service) => ({
    params: { slug: service.id },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://wecleanshine.com';
const canonical = `${siteUrl}/services/${service.id}/`;
const title = `${service.title} | Clean & Shine Services`;
const description =
  service.longDescription.length > 160
    ? `${service.longDescription.slice(0, 157)}…`
    : service.longDescription;
const ogImage = service.image.startsWith('http') ? service.image : `${siteUrl}${service.image}`;
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Header client:load />
  <WhatsAppButton />
  <main>
    <div class="pt-[var(--header-offset)] min-h-screen bg-white">
      <div class="relative h-[40vh] sm:h-[60vh] overflow-hidden bg-slate-100">
        <img src={service.image} alt={service.title} class="w-full h-full object-cover" width="1920" height="1080" />
        <div class="absolute inset-0 bg-slate-900/60 flex items-center justify-center text-center px-4">
          <div class="max-w-4xl">
            <a
              href="/#services"
              class="text-white/70 hover:text-white mb-8 flex items-center justify-center space-x-2 mx-auto uppercase tracking-widest text-[10px] font-bold transition-colors"
            >
              <i class="fa-solid fa-arrow-left"></i>
              <span>Back to all services</span>
            </a>
            <h1 class="text-4xl sm:text-7xl font-bold text-white mb-6 tracking-tighter">{service.title}</h1>
            <div class="w-20 h-1 bg-blue-500 mx-auto rounded-full"></div>
          </div>
        </div>
      </div>

      <div class="container mx-auto px-4 py-20">
        <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">
          <div class="lg:w-2/3">
            <h2 class="text-3xl font-bold text-slate-950 mb-8 uppercase tracking-tight">Premium Service Overview</h2>
            <p class="text-slate-600 text-xl leading-relaxed mb-10 font-light">{service.longDescription}</p>

            <div class="grid sm:grid-cols-2 gap-8 mb-12">
              {
                service.features.map((feature) => (
                  <div class="flex items-start space-x-4">
                    <div class="w-8 h-8 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center shrink-0">
                      <i class="fa-solid fa-check text-xs"></i>
                    </div>
                    <span class="text-slate-700 font-medium">{feature}</span>
                  </div>
                ))
              }
            </div>

            <div class="bg-slate-50 p-8 sm:p-12 rounded-3xl border border-slate-100">
              <h3 class="text-xl font-bold mb-6 flex items-center space-x-3">
                <i class="fa-solid fa-circle-info text-blue-500"></i>
                <span>Why choose our {service.title}?</span>
              </h3>
              <p class="text-slate-500 leading-relaxed mb-8">
                Every member of our team is specifically trained for our {service.title.toLowerCase()} protocols. We use
                high-grade equipment and specialized chemicals to ensure a level of clean that exceeds industry standards.
              </p>
              <a
                href="/#contact"
                class="inline-block px-10 py-4 bg-blue-600 text-white font-bold tracking-widest uppercase text-xs rounded-xl hover:bg-blue-700 transition-all shadow-xl"
              >
                REQUEST A QUOTE
              </a>
            </div>
          </div>

          <div class="lg:w-1/3">
            <div class="sticky top-32 space-y-8">
              <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-xl shadow-slate-200/50">
                <h4 class="text-sm font-bold uppercase tracking-widest text-slate-400 mb-6">Need Immediate Help?</h4>
                <div class="space-y-6">
                  <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-blue-600 text-white rounded-xl flex items-center justify-center">
                      <i class="fa-solid fa-phone"></i>
                    </div>
                    <div>
                      <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Call or Text</p>
                      <a href="tel:+16786502983" class="font-bold text-lg hover:underline decoration-blue-500/60"
                        >678 650 2983</a
                      >
                    </div>
                  </div>
                  <div class="flex items-center space-x-4">
                    <div class="w-12 h-12 bg-slate-100 text-slate-900 rounded-xl flex items-center justify-center">
                      <i class="fa-solid fa-calendar-check"></i>
                    </div>
                    <div>
                      <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Online Booking</p>
                      <p class="font-bold text-lg">24/7 Available</p>
                    </div>
                  </div>
                </div>
              </div>

              <div class="relative group rounded-3xl overflow-hidden h-64 shadow-2xl bg-blue-600">
                <img
                  src={FALLBACK_IMG}
                  alt="Quality Assurance"
                  loading="lazy"
                  decoding="async"
                  fetchpriority="low"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  width="640"
                  height="256"
                />
                <div class="absolute inset-0 bg-blue-600/70 flex items-center justify-center p-8 text-center text-white backdrop-blur-[2px]">
                  <div>
                    <h5 class="font-bold text-xl mb-2">Quality Guarantee</h5>
                    <p class="text-xs text-blue-100">If you're not satisfied, we'll re-clean for free.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
