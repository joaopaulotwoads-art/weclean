---
import TrustBadgesStrip from './TrustBadgesStrip.astro';
---

<section id="contact" class="py-16 sm:py-32 bg-slate-50 relative overflow-hidden bg-bubble-pattern">
  <div class="container mx-auto px-4 relative z-10">
    <div class="flex flex-col lg:flex-row bg-white rounded-2xl sm:rounded-3xl shadow-2xl overflow-hidden border border-slate-100">
      <div
        class="w-full lg:w-1/3 bg-gradient-to-br from-sky-500 via-blue-500 to-blue-700 p-8 sm:p-12 lg:p-16 text-white flex flex-col justify-between"
      >
        <div>
          <span class="text-white/90 font-semibold tracking-[0.28em] text-[10px] uppercase mb-4 sm:mb-6 block font-display">Contact Us</span>
          <h2 class="text-3xl sm:text-4xl font-bold mb-6 sm:mb-8 leading-tight">Request Your Cleaning Estimate</h2>
          <p class="text-white/90 mb-8 sm:mb-12 font-normal text-sm sm:text-base font-display leading-relaxed">
            Fill out the form for a free estimate or send us a text message. We will reply as soon as possible.
          </p>
        </div>

        <div class="space-y-6 sm:space-y-8">
          <div class="flex items-center space-x-4 sm:space-x-6">
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white/20 rounded-xl flex items-center justify-center text-white">
              <i class="fa-solid fa-phone text-sm sm:text-base"></i>
            </div>
            <div>
              <p class="text-[9px] uppercase tracking-widest text-white/80 font-semibold mb-0.5 sm:mb-1 font-display">Call or Text</p>
              <a href="tel:+16786502983" class="font-semibold text-lg sm:text-xl hover:underline decoration-white/60">678 650 2983</a>
            </div>
          </div>

          <div class="flex items-center space-x-4 sm:space-x-6">
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-white/20 rounded-xl flex items-center justify-center text-white">
              <i class="fa-solid fa-envelope text-sm sm:text-base"></i>
            </div>
            <div>
              <p class="text-[9px] uppercase tracking-widest text-white/80 font-semibold mb-0.5 sm:mb-1 font-display">Email Us</p>
              <p class="font-semibold text-sm sm:text-base">cleaneshine@hotmail.com</p>
            </div>
          </div>
        </div>
      </div>

      <div class="w-full lg:w-2/3 p-8 sm:p-12 lg:p-16">
        <form class="space-y-4 sm:space-y-6" action="https://formsubmit.co/cleaneshine@hotmail.com" method="POST">
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_cc" value="joaopaulotwoads@gmail.com" />
          <input type="hidden" name="_subject" value="New cleaning estimate request from Clean & Shine site" />
          <div class="grid sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="space-y-1 sm:space-y-2">
              <label class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest ml-1 font-display">Full Name</label>
              <input
                required
                name="fullName"
                type="text"
                placeholder="John Doe"
                class="w-full px-4 sm:px-5 py-3 sm:py-4 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-sm"
              />
            </div>
            <div class="space-y-1 sm:space-y-2">
              <label class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest ml-1 font-display">Email Address</label>
              <input
                required
                name="email"
                type="email"
                placeholder="john@example.com"
                class="w-full px-4 sm:px-5 py-3 sm:py-4 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-sm"
              />
            </div>
          </div>

          <div class="grid sm:grid-cols-2 gap-4 sm:gap-6">
            <div class="space-y-1 sm:space-y-2">
              <label class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest ml-1 font-display">Service Type</label>
              <select
                name="serviceType"
                class="w-full px-4 sm:px-5 py-3 sm:py-4 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-sm text-slate-600"
              >
                <option>Regular Cleaning</option>
                <option>Commercial Cleaning</option>
                <option>Move-in/Move-out Cleaning</option>
              </select>
            </div>
            <div class="space-y-1 sm:space-y-2">
              <label class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest ml-1 font-display">Phone Number</label>
              <input
                required
                name="phone"
                type="tel"
                placeholder="(404) 555-0000"
                class="w-full px-4 sm:px-5 py-3 sm:py-4 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-sm"
              />
            </div>
          </div>

          <div class="space-y-1 sm:space-y-2">
            <label class="text-[10px] font-semibold text-slate-500 uppercase tracking-widest ml-1 font-display">Message / Details</label>
            <textarea
              rows="3"
              name="message"
              placeholder="Tell us about your home size and requirements..."
              class="w-full px-4 sm:px-5 py-3 sm:py-4 bg-slate-50 border border-slate-100 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 outline-none transition-all text-sm"
            ></textarea>
          </div>

          <div class="pt-2 border-t border-slate-100">
            <p class="text-center text-[10px] font-semibold uppercase tracking-[0.22em] text-slate-500 mb-4 font-display">
              Rated on trusted platforms
            </p>
            <TrustBadgesStrip variant="compact" />
          </div>

          <button
            type="submit"
            class="w-full py-4 sm:py-5 bg-gradient-to-r from-sky-600 to-blue-700 text-white font-bold tracking-[0.2em] uppercase text-xs sm:text-sm rounded-xl hover:from-sky-500 hover:to-blue-600 transition-all shadow-xl disabled:opacity-70 flex items-center justify-center space-x-3 mt-2"
          >
            <span>REQUEST ESTIMATE</span>
            <i class="fa-solid fa-paper-plane text-xs"></i>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
