---
import { NAV_LINKS } from '@/constants';
---

<footer class="bg-slate-900 text-white pt-24 pb-12">
  <div class="container mx-auto px-4">
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      <div class="col-span-1">
        <img
          src="/images/logo-header.png"
          alt="Clean &amp; Shine"
          class="mb-8 h-14 w-auto max-w-full sm:h-16 md:h-[72px]"
          decoding="async"
          width="444"
          height="315"
        />
        <p class="text-slate-400 text-sm leading-relaxed mb-8">
          Professional cleaning services in Georgia. Dedication, care, and trust for your home and business.
        </p>
        <div class="flex space-x-4">
          <a href="#" class="w-10 h-10 bg-white/5 flex items-center justify-center rounded-lg hover:text-blue-400 transition-colors" aria-label="Instagram"
            ><i class="fa-brands fa-instagram"></i></a
          >
          <a href="#" class="w-10 h-10 bg-white/5 flex items-center justify-center rounded-lg hover:text-blue-400 transition-colors" aria-label="Facebook"
            ><i class="fa-brands fa-facebook-f"></i></a
          >
        </div>
      </div>

      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-8 text-blue-400">Navigation</h4>
        <ul class="space-y-4">
          {
            NAV_LINKS.map((link) => (
              <li>
                <a href={link.href} class="text-slate-400 text-sm hover:text-white transition-colors">{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-8 text-blue-400">Services</h4>
        <ul class="space-y-4 text-slate-400 text-sm">
          <li>Regular Cleaning</li>
          <li>Commercial Cleaning</li>
          <li>Move-in/Move-out Cleaning</li>
        </ul>
      </div>

      <div>
        <h4 class="font-bold uppercase tracking-widest text-xs mb-8 text-blue-400">Newsletter</h4>
        <p class="text-slate-400 text-sm mb-6">Subscribe for cleaning tips and exclusive offers.</p>
        <form class="flex bg-white/5 rounded-xl p-1" action="#" method="get">
          <input
            type="email"
            name="email"
            placeholder="Email"
            class="bg-transparent border-none px-4 py-2 text-sm flex-1 focus:outline-none text-white"
          />
          <button type="submit" class="bg-blue-600 text-white px-4 py-2 text-xs font-bold uppercase rounded-lg">JOIN</button>
        </form>
      </div>
    </div>

    <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between items-center text-[10px] text-slate-500 font-bold uppercase tracking-widest">
      <p>© 2026 Clean &amp; Shine Services. All Rights Reserved.</p>
      <div class="flex space-x-8 mt-6 md:mt-0">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
