---
import { WHATSAPP_NUMBER, WHATSAPP_MESSAGE } from '@/constants';
const whatsappUrl = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_MESSAGE}`;
---

<a
  href={whatsappUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 sm:bottom-10 sm:right-10 z-[100] w-14 h-14 sm:w-16 sm:h-16 bg-[#25D366] text-white rounded-full shadow-2xl flex items-center justify-center hover:scale-110 transition-transform focus:outline-none group active:scale-95 animate-bounce-slow"
  aria-label="Contact us on WhatsApp"
>
  <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-20" aria-hidden="true"></span>
  <i class="fa-brands fa-whatsapp text-2xl sm:text-3xl relative z-10"></i>
  <span
    class="absolute right-full mr-4 bg-white text-slate-900 px-3 py-1.5 rounded-lg text-[10px] font-bold uppercase tracking-widest shadow-xl opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none border border-slate-100"
  >
    Chat on WhatsApp
  </span>
</a>
