---
import { SERVICES } from '@/constants';
---

<section id="services" class="relative py-16 sm:py-32 bg-white bg-bubble-pattern">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16 sm:mb-24 px-4">
      <span class="text-blue-600 font-semibold tracking-[0.28em] text-[10px] uppercase mb-4 block font-display">Service Types</span>
      <h2 class="text-3xl sm:text-5xl lg:text-6xl font-bold text-slate-950 mb-6 tracking-tight">Professional Specialties</h2>
      <div class="w-20 sm:w-24 h-1.5 bg-blue-400 mx-auto rounded-full"></div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      {
        SERVICES.map((service) => (
          <article class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-2xl transition-all duration-500 border border-slate-100 flex flex-col h-full">
            <div class="relative h-48 sm:h-64 overflow-hidden bg-slate-100">
              <img
                src={service.image}
                alt={service.title}
                width={service.imageWidth}
                height={service.imageHeight}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
                sizes="(max-width: 1023px) 100vw, 33vw"
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-slate-950/60 to-transparent opacity-40" />
              <div class="absolute top-4 left-4 sm:top-6 sm:left-6 w-10 h-10 sm:w-12 sm:h-12 bg-white flex items-center justify-center rounded-xl shadow-xl text-blue-600">
                <i class={`${service.icon} text-base sm:text-lg`} />
              </div>
            </div>

            <div class="p-6 sm:p-8 flex flex-col flex-1">
              <h3 class="text-xl sm:text-2xl font-bold mb-3 sm:mb-4 text-slate-950 group-hover:text-blue-600 transition-colors">
                {service.title}
              </h3>
              <p class="text-slate-500 text-xs sm:text-sm leading-relaxed mb-6 sm:mb-8 flex-1">{service.description}</p>
              <a
                href={`/services/${service.id}/`}
                class="inline-flex items-center space-x-3 text-[9px] sm:text-[10px] font-bold tracking-[0.2em] uppercase text-blue-600 group-hover:translate-x-2 transition-transform"
              >
                <span>Service Details</span>
                <i class="fa-solid fa-arrow-right-long" />
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
