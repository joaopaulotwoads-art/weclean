---
/**
 * LCP: <img> WebP + h1 inline — poucas camadas por cima (só scrim) para o PSI/LH13.
 * Preload: /images/commercial-cleaning.webp
 */
---

<section
  id="home"
  class="relative overflow-hidden pt-[calc(var(--header-offset)+1.25rem)] scroll-mt-[calc(var(--header-offset)+1.25rem)] pb-10 sm:flex sm:items-center sm:justify-center sm:pb-16 sm:pt-[calc(var(--header-offset)+0.5rem)] sm:scroll-mt-[calc(var(--header-offset)+0.5rem)]"
>
  <img
    src="/images/commercial-cleaning.webp"
    alt="Professional commercial cleaning team"
    width="1024"
    height="682"
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
    style="position:absolute;left:0;top:0;width:100%;height:100%;object-fit:cover;z-index:0;display:block;"
  />
  <!-- Scrim só na parte inferior: o <img> permanece a área principal visível (LCP). -->
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-[min(58%,420px)]"
    style="background: linear-gradient(to top, rgba(15, 23, 42, 0.72), rgba(37, 99, 168, 0.28), transparent);"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative z-20 mx-auto w-full max-w-4xl px-4 pt-2 text-center text-white sm:pt-0 md:max-w-3xl lg:max-w-2xl xl:max-w-3xl"
  >
    <span
      class="inline-block bg-white/5 backdrop-blur-md border border-white/10 px-4 py-1.5 rounded-full text-white font-medium tracking-[0.18em] uppercase text-[9px] mb-4 sm:mb-6 font-display"
    >
      Clean &amp; Shine Services • Georgia
    </span>
    <h1
      class="font-semibold mb-4 tracking-tight drop-shadow-2xl sm:mb-6"
      style="color: #fff; font-weight: 600; font-size: clamp(1.75rem, 5.5vw, 3.75rem); line-height: 1.15; margin: 0 0 1rem; text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);"
    >
      Professional Cleaning Services You Can Trust!
    </h1>
    <p
      class="text-sm sm:text-lg md:text-xl mb-6 text-white/95 max-w-2xl mx-auto font-normal leading-relaxed px-2 sm:px-4 sm:mb-10 font-display"
    >
      Delivering consistent, high-quality cleaning for homes and businesses. Reliable, insured, and
      committed to excellence.
    </p>
    <div class="relative z-20 flex flex-col sm:flex-row items-center justify-center gap-4 px-2 sm:gap-5 sm:px-0">
      <a
        href="/#contact"
        class="relative z-20 w-full sm:w-auto px-10 py-4 bg-white text-slate-950 font-bold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-slate-100 transition-all transform hover:-translate-y-1 shadow-2xl ring-2 ring-white/90"
      >
        REQUEST A FREE ESTIMATE
      </a>
      <a
        href="/#services"
        class="relative z-20 w-full sm:w-auto px-10 py-4 border-2 border-white/90 bg-white/10 text-white font-semibold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-white/20 transition-all transform hover:-translate-y-1 shadow-xl flex items-center justify-center space-x-3 backdrop-blur-sm"
      >
        <span>VIEW SERVICES &amp; CHECKLIST</span>
      </a>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 hidden sm:block">
    <svg class="h-8 w-8 text-white/50" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path>
    </svg>
  </div>
</section>
