---
/**
 * LCP: <img> WebP + h1 inline — poucas camadas por cima (só scrim) para o PSI/LH13.
 * Preload: /images/commercial-cleaning.webp
 */
---

<section
  id="home"
  class="relative overflow-hidden pt-[calc(var(--header-offset)+1.25rem)] scroll-mt-[calc(var(--header-offset)+1.25rem)] pb-10 sm:pb-16 sm:pt-[calc(var(--header-offset)+0.5rem)] sm:scroll-mt-[calc(var(--header-offset)+0.5rem)]"
>
  <div class="mx-auto w-full max-w-5xl px-4 text-center">
    <span
      class="inline-block border border-slate-300 px-4 py-1.5 rounded-full text-slate-700 font-medium tracking-[0.18em] uppercase text-[9px] mb-4 sm:mb-6 font-display"
    >
      Clean &amp; Shine Services • Georgia
    </span>
    <h1
      class="font-semibold mb-4 tracking-tight sm:mb-6"
      style="color: #0f172a; font-weight: 600; font-size: clamp(1.75rem, 5.5vw, 3.75rem); line-height: 1.15; margin: 0 0 1rem;"
    >
      Professional Cleaning Services You Can Trust!
    </h1>
    <img
      src="/images/commercial-cleaning.webp"
      alt="Professional commercial cleaning team"
      width="1024"
      height="682"
      loading="eager"
      fetchpriority="high"
      class="mx-auto mb-6 w-full h-auto max-w-5xl rounded-2xl object-cover shadow-lg"
    />
    <p
      class="text-sm sm:text-lg md:text-xl mb-6 text-slate-700 max-w-2xl mx-auto font-normal leading-relaxed px-2 sm:px-4 sm:mb-10 font-display"
    >
      Delivering consistent, high-quality cleaning for homes and businesses. Reliable, insured, and
      committed to excellence.
    </p>
    <div class="relative z-20 flex flex-col sm:flex-row items-center justify-center gap-4 px-2 sm:gap-5 sm:px-0">
      <a
        href="/#contact"
        class="relative z-20 w-full sm:w-auto px-10 py-4 bg-slate-900 text-white font-bold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-slate-800 transition-all transform hover:-translate-y-1 shadow-xl"
      >
        REQUEST A FREE ESTIMATE
      </a>
      <a
        href="/#services"
        class="relative z-20 w-full sm:w-auto px-10 py-4 border-2 border-slate-300 bg-white text-slate-900 font-semibold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-slate-100 transition-all transform hover:-translate-y-1 shadow-xl flex items-center justify-center space-x-3"
      >
        <span>VIEW SERVICES &amp; CHECKLIST</span>
      </a>
    </div>
  </div>
</section>
