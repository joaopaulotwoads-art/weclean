---
/* Static hero — full HTML for SEO */
---

<section
  id="home"
  class="relative min-h-0 overflow-hidden bg-gradient-to-br from-shine-hero-start via-shine-hero-mid to-shine-hero-end pt-[calc(var(--header-offset)+1.25rem)] scroll-mt-[calc(var(--header-offset)+1.25rem)] pb-10 sm:flex sm:min-h-[70vh] sm:items-center sm:justify-center sm:pb-16 md:min-h-[80vh] sm:pt-[calc(var(--header-offset)+0.5rem)] sm:scroll-mt-[calc(var(--header-offset)+0.5rem)]"
>
  <div
    class="absolute inset-0 pointer-events-none opacity-[0.42] bg-[radial-gradient(ellipse_at_50%_20%,_rgba(255,255,255,0.22),_transparent_55%),radial-gradient(circle_at_80%_70%,_rgba(56,189,248,0.18),_transparent_50%),radial-gradient(circle_at_bottom,_rgba(15,23,42,0.35),_transparent_55%)]"
  >
  </div>

  <div
    class="absolute inset-0 pointer-events-none opacity-[0.035]"
    style="background-image: radial-gradient(circle, rgba(255,255,255,0.65) 1px, transparent 1px); background-size: 22px 22px;"
    aria-hidden="true"
  >
  </div>

  <div
    class="pointer-events-none absolute bottom-0 right-0 z-0 w-[min(46vw,12rem)] translate-x-[26%] translate-y-[6%] opacity-20 sm:w-[min(40vw,13rem)] sm:translate-x-[20%] sm:translate-y-[4%] sm:opacity-25 md:bottom-auto md:top-1/2 md:right-[-0.25rem] md:w-[min(38vw,24rem)] md:max-w-none md:translate-x-0 md:translate-y-0 md:-translate-y-1/2 md:opacity-[0.38] lg:-right-2 xl:right-4 xl:w-[min(34vw,28rem)]"
    aria-hidden="true"
  >
    <svg
      class="h-auto w-full drop-shadow-[0_0_20px_rgba(147,197,253,0.08)]"
      viewBox="0 0 420 420"
      fill="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <defs>
        <radialGradient id="hbh-bubble" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgb(191, 219, 254)" stop-opacity="0.55"></stop>
          <stop offset="55%" stop-color="rgb(147, 197, 253)" stop-opacity="0.22"></stop>
          <stop offset="100%" stop-color="rgb(30, 58, 95)" stop-opacity="0"></stop>
        </radialGradient>
        <radialGradient id="hbh-glow" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgb(255, 255, 255)" stop-opacity="0.35"></stop>
          <stop offset="100%" stop-color="rgb(255, 255, 255)" stop-opacity="0"></stop>
        </radialGradient>
        <filter id="hbh-soft" x="-20%" y="-20%" width="140%" height="140%">
          <feGaussianBlur in="SourceGraphic" stdDeviation="2"></feGaussianBlur>
        </filter>
      </defs>
      <g opacity="0.92">
        <circle cx="310" cy="120" r="78" fill="url(#hbh-bubble)"></circle>
        <circle cx="200" cy="260" r="105" fill="url(#hbh-bubble)" opacity="0.85"></circle>
        <circle cx="340" cy="280" r="52" fill="url(#hbh-bubble)" opacity="0.75"></circle>
        <circle cx="120" cy="180" r="38" fill="url(#hbh-glow)" filter="url(#hbh-soft)" opacity="0.6"></circle>
        <circle cx="260" cy="200" r="22" fill="rgb(255,255,255)" opacity="0.18"></circle>
        <circle cx="180" cy="320" r="18" fill="rgb(255,255,255)" opacity="0.14"></circle>
      </g>
      <g fill="rgb(186, 230, 253)" opacity="0.55">
        <path d="M88 95l4 12 12 4-12 4-4 12-4-12-12-4 12-4 4-12z"></path>
        <path d="M320 48l3 9 9 3-9 3-3 9-3-9-9-3 9-3 3-9z"></path>
        <path d="M360 180l2 6 6 2-6 2-2 6-2-6-6-2 6-2 2-6z"></path>
      </g>
      <g stroke="rgb(147, 197, 253)" stroke-width="1.2" stroke-linecap="round" opacity="0.4">
        <path d="M70 220l18 10M79 210v22M100 248l14-16M130 90l20 8"></path>
      </g>
    </svg>
  </div>

  <div
    class="relative z-20 mx-auto w-full max-w-4xl px-4 pt-2 text-center text-white sm:pt-0 md:max-w-3xl lg:max-w-2xl xl:max-w-3xl"
  >
    <span
      class="inline-block bg-white/5 backdrop-blur-md border border-white/10 px-4 py-1.5 rounded-full text-white font-medium tracking-[0.18em] uppercase text-[9px] mb-4 sm:mb-6 font-display"
    >
      Clean &amp; Shine Services • Georgia
    </span>
    <h1
      class="text-3xl sm:text-5xl md:text-6xl font-semibold mb-4 tracking-tight leading-tight drop-shadow-2xl sm:mb-6"
    >
      Professional Cleaning Services You Can Trust!
    </h1>
    <p
      class="text-sm sm:text-lg md:text-xl mb-6 text-white/95 max-w-2xl mx-auto font-normal leading-relaxed px-2 sm:px-4 sm:mb-10 font-display"
    >
      Delivering consistent, high-quality cleaning for homes and businesses. Reliable, insured, and
      committed to excellence.
    </p>
    <div class="relative z-20 flex flex-col sm:flex-row items-center justify-center gap-4 px-2 sm:gap-5 sm:px-0">
      <a
        href="/#contact"
        class="relative z-20 w-full sm:w-auto px-10 py-4 bg-white text-slate-950 font-bold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-slate-100 transition-all transform hover:-translate-y-1 shadow-2xl ring-2 ring-white/90"
      >
        REQUEST A FREE ESTIMATE
      </a>
      <a
        href="/#services"
        class="relative z-20 w-full sm:w-auto px-10 py-4 border-2 border-white/90 bg-white/10 text-white font-semibold tracking-[0.18em] uppercase text-[10px] rounded-xl hover:bg-white/20 transition-all transform hover:-translate-y-1 shadow-xl flex items-center justify-center space-x-3 backdrop-blur-sm"
      >
        <span>VIEW SERVICES &amp; CHECKLIST</span>
      </a>
    </div>
  </div>

  <div class="absolute bottom-6 left-1/2 z-10 -translate-x-1/2 animate-bounce hidden sm:block">
    <i class="fa-solid fa-chevron-down text-white/50 text-2xl"></i>
  </div>
</section>
